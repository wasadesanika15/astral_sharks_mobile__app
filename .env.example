# Copy to .env and adjust. Restart Expo after changes.

# HTTP + Socket.IO base (http:// or https:// only — never ws://)
# Same machine + Expo Web:
# EXPO_PUBLIC_API_URL=http://localhost:3000
# Physical device on same Wi‑Fi (use your Mac’s LAN IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

EXPO_PUBLIC_API_URL=http://localhost:3000

# Optional; default /socket.io — must match server
# EXPO_PUBLIC_SOCKET_PATH=/socket.io
